    "rtl_files": [
      "rtl/i2c.sv",
      "rtl/i2c_bus_monitor.sv",
      "rtl/i2c_controller_fsm.sv",
      "rtl/i2c_core.sv",
      "rtl/i2c_fifo_sync_sram_adapter.sv",
      "rtl/i2c_fifos.sv",
