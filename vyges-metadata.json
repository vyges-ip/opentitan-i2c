  "interfaces": [
    {
      "type": "bus",
      "direction": "input",
      "protocol": "TL-UL",
      "width": 32,
      "description": "TL-UL host interface for register access",
      "signals": [
        {
          "name": "clk_i",
          "direction": "input",
          "type": "clock",
          "width": 1,
          "description": "System clock"
        },
        {
          "name": "rst_ni",
          "direction": "input",
          "type": "reset",
          "width": 1,
          "active_level": "low",
          "description": "Active-low synchronous reset"
        },
        {
          "name": "tl_i",
          "direction": "input",
          "type": "data",
          "width": 1,
          "description": "TL-UL host-to-device (tl_h2d_t struct) \u2014 connect to xbar slave port"
        },
        {
          "name": "tl_o",
          "direction": "output",
          "type": "data",
          "width": 1,
          "description": "TL-UL device-to-host (tl_d2h_t struct) \u2014 connect to xbar slave port"
        }
      ]
    },
    {
      "type": "bus",
      "direction": "output",
      "protocol": "I2C",
      "description": "I2C host; connects to I2C bus (SCL, SDA)",
      "signals": [
        {
          "name": "cio_scl_i",
          "direction": "input",
          "type": "data",
          "width": 1,
          "description": "I2C clock input"
        },
        {
          "name": "cio_scl_o",
          "direction": "output",
          "type": "data",
          "width": 1,
          "description": "I2C clock output"
        },
        {
          "name": "cio_scl_en_o",
          "direction": "output",
          "type": "control",
          "width": 1,
          "description": "I2C clock output enable (open-drain)"
        },
        {
          "name": "cio_sda_i",
          "direction": "input",
          "type": "data",
          "width": 1,
          "description": "I2C data input"
        },
        {
          "name": "cio_sda_o",
          "direction": "output",
          "type": "data",
          "width": 1,
          "description": "I2C data output"
        },
        {
          "name": "cio_sda_en_o",
          "direction": "output",
          "type": "control",
          "width": 1,
          "description": "I2C data output enable (open-drain)"
        },
        {
          "name": "intr_fmt_threshold_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "Format FIFO threshold interrupt"
        },
        {
          "name": "intr_rx_threshold_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "RX FIFO threshold interrupt"
        },
        {
          "name": "intr_acq_threshold_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "Acquire FIFO threshold interrupt"
        },
        {
          "name": "intr_nak_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "NAK received interrupt"
        },
        {
          "name": "intr_scl_interference_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "SCL bus contention interrupt"
        },
        {
          "name": "intr_sda_interference_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "SDA bus contention interrupt"
        },
        {
          "name": "intr_stretch_timeout_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "SCL stretch timeout interrupt"
        },
        {
          "name": "intr_sda_unstable_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "SDA unstable during clock high interrupt"
        },
        {
          "name": "intr_cmd_complete_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "Command complete interrupt"
        },
        {
          "name": "intr_tx_stretch_o",
          "direction": "output",
          "type": "interrupt",
          "width": 1,
          "description": "TX FIFO stretch interrupt"
        }
      ]
    }
  ],
